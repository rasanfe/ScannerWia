<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- WIA via Interop.WIA.dll PRE-generado con tlbimp (desde C:\Windows\System32\wiaaut.dll).
         Así compila con 'dotnet build/publish' FUERA de Visual Studio (sin el error MSB4803 que
         daba el antiguo <COMReference>, que obligaba a ejecutar tlbimp en cada build).
         EmbedInteropTypes=true => los tipos WIA se incrustan en el DLL del proyecto; el interop
         solo hace falta al COMPILAR, NO en runtime/despliegue (Private=false evita copiarlo a bin). -->
    <Reference Include="Interop.WIA">
      <HintPath>Interop.WIA.dll</HintPath>
      <EmbedInteropTypes>true</EmbedInteropTypes>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Tesseract" Version="5.2.0" />
  </ItemGroup>

</Project>
